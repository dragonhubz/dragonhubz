    local fluentGui = game:GetService("CoreGui"):FindFirstChild("Fluent") or game:GetService("CoreGui"):FindFirstChild("FluentUI")
    if fluentGui then
        for _, obj in pairs(fluentGui:GetDescendants()) do
            if obj:IsA("Frame") and obj.BackgroundColor3 == Color3.fromRGB(35, 35, 45) then
                obj.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            end
            if obj:IsA("TextLabel") and obj.TextColor3 == Color3.fromRGB(0, 255, 255) then
                obj.TextColor3 = Color3.fromRGB(255, 115, 0)
            end
        end
    end
end)

