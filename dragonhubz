-- Lógica de Level e Quests (Base estrutural do Banana Cat)
local v5 = game.PlaceId
if v5 == 2753915549 then Sea1 = true elseif v5 == 4442272183 then Sea2 = true elseif v5 == 7449423635 then Sea3 = true end

function CheckLevel()
    local v7 = game:GetService("Players").LocalPlayer.Data.Level.Value
    if Sea1 then
        if v7 == 1 or (v7 <= 9 or _G.SelectMonster == "Bandit") then
            Ms = "Bandit" NameQuest = "BanditQuest1" QuestLv = 1 NameMon = "Bandit"
            CFrameQ = CFrame.new(1060.9383544922, 16.455066680908, 1547.7841796875)
            CFrameMon = CFrame.new(1038.5533447266, 41.296249389648, 1576.5098876953)
        elseif v7 >= 10 and v7 <= 14 then
            Ms = "Monkey" NameQuest = "JungleQuest" QuestLv = 1 NameMon = "Monkey"
            CFrameQ = CFrame.new(-1601.6553955078, 36.85213470459, 153.38809204102)
            CFrameMon = CFrame.new(-1448.1446533203, 50.851993560791, 63.60718536377)
        end
    end
end

