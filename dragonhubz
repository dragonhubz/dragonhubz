-- Função para criar botões de Ligar/Desligar (Toggles)
local function CreateToggle(name, globalVar)
    local ToggleButton = Instance.new("TextButton")
    ToggleButton.Name = name
    ToggleButton.Parent = Container
    ToggleButton.Size = UDim2.new(1, -10, 0, 35)
    ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    ToggleButton.Font = Enum.Font.SourceSansBold
    ToggleButton.Text = name .. " : DESLIGADO"
    ToggleButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    ToggleButton.TextSize = 14
    
    ToggleButton.MouseButton1Click:Connect(function()
        _G[globalVar] = not _G[globalVar]
        if _G[globalVar] then
            ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 115, 0)
            ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            ToggleButton.Text = name .. " : LIGADO"
        else
            ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            ToggleButton.TextColor3 = Color3.fromRGB(200, 200, 200)
            ToggleButton.Text = name .. " : DESLIGADO"
        end
    end)
end

